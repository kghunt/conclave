# Database — set the same password in both lines
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
DATABASE_URL=postgres://conclave:change-me-to-a-strong-random-password@postgres:5432/conclave?sslmode=disable

# Auth
JWT_SECRET=change-me-to-a-long-random-string
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# URL the app is reachable at (no trailing slash, must be https:// in production)
BASE_URL=https://chat.yourdomain.com

# Optional: grants access to the instance admin panel
INSTANCE_ADMIN_EMAIL=you@example.com

# Optional: push notifications (PWA)
# Generate once with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BExamplePublicKey...
# VAPID_PRIVATE_KEY=example-private-key...
# VAPID_EMAIL=admin@yourdomain.com   # shown to push services, does not need to be valid

# Optional: pin to a specific image version instead of latest
# TAG=v1.2.3
