{
  "productName": "conclave-presence",
  "identifier": "com.conclave.presence",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Conclave Presence",
        "width": 400,
        "height": 500,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Shows your gaming status on Conclave",
    "longDescription": "Runs in the system tray, detects running games, and reports your status to your Conclave server."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["conclave"]
      }
    }
  }
}
